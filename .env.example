# Teams 晨間推播 — 本機設定檔
# 複製此檔為 .env 後填入你的 Webhook URL

# 必填：Teams Webhook URL（從 Teams 頻道 → ⋯ → Workflows 取得）
TEAMS_WEBHOOK_URL=

# HR 戰略快報專用 Webhook（建議：指向「發給個人」的 Power Automate Workflow）
# 設定方式見 docs/hr_teams_dm_setup.md
# HR_TEAMS_WEBHOOK_URL=

# 第二位（以上）收件人的額外 Webhook（複製 Power Automate 流程後取得）
# HR_TEAMS_WEBHOOK_URL_EXTRA=

# 選填：OpenAI API Key（AI 模式需要）
# OPENAI_API_KEY=sk-...

# 選填：Gemini API Key
# GEMINI_API_KEY=

# 選填：圖片 API（未設定時使用 Wikimedia 免費搜尋）
# UNSPLASH_ACCESS_KEY=
# PEXELS_API_KEY=

# Operations
MESSAGE_MODE=mixed
MESSAGE_STRATEGY=random
ENABLE_IMAGES=true
ENABLE_MAJOR_NEWS=true
MAJOR_NEWS_THRESHOLD=70
# Weekly management quote day: 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri (default Wed)
MANAGEMENT_QUOTE_WEEKDAY=2
# Biweekly interaction Forms link (optional — when unset, all prompts use channel replies)
# INTERACTION_FORMS_URL=https://forms.office.com/...

# 測試用（本機腳本會自動設定，通常不需手動改）
# DRY_RUN=true
# SKIP_WORKDAY_CHECK=true
# TEST_BATCH_COUNT=5
